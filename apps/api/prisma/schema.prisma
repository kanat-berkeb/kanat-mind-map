generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum ReviewStatus {
  candidate
  validated
  needs_review
  approved
  rejected
}

enum PublicationStatus {
  unpublished
  publish_pending
  published
  publish_failed
}

enum ValidityStatus {
  active
  expired
  superseded
  retracted
  conflicted
}

enum ValidationStatus {
  passed
  failed
  warning
  skipped
  needs_review
}

enum ValidationSeverity {
  info
  warning
  error
  critical
}

enum ReviewDecisionType {
  approved
  rejected
}

enum ConflictStatus {
  open
  needs_review
  resolved
  dismissed
}

enum FreshnessStatus {
  current
  stale
  needs_verification
}

enum MemoryGenerationSource {
  curated_kg
  published_assertions
}

enum DocumentStatus {
  uploaded
  extracting
  extracted
  failed
}

model Document {
  id                 String          @id @default(cuid())
  fileName           String
  fileType           String
  sourceType         String
  storagePath        String
  status             DocumentStatus  @default(uploaded)
  accessPolicy       String
  extractionMetadata Json?
  extractionWarnings Json?
  extractionError    String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  evidenceAtoms      EvidenceAtom[]
  candidateFacts     CandidateFact[]

  @@index([status, createdAt])
}

model EvidenceAtom {
  id                String   @id @default(cuid())
  atomId            String
  documentId        String
  sourceId          String
  sourceVersion     String
  atomIndex         Int
  atomType          String
  sourceType        String
  text              String
  structuredContent Json?
  location          Json?
  sectionPath       String[]
  parentAtomId      String?
  qualityScore      Int
  contentHash       String
  accessPolicy      String
  metadata          Json
  createdAt         DateTime @default(now())
  document          Document @relation(fields: [documentId], references: [id], onDelete: Restrict)

  @@unique([documentId, atomId])
  @@index([documentId, atomIndex])
}

model CandidateFact {
  id                String             @id @default(cuid())
  subjectName       String
  subjectType       String
  predicate         String
  objectName        String
  objectType        String
  objectProperties  Json?
  evidenceAtomIds   String[]
  sourceDocumentId  String?
  evidenceText      String
  llmConfidence     Float?
  approvalScore     Int?
  reviewStatus      ReviewStatus       @default(candidate)
  publicationStatus PublicationStatus  @default(unpublished)
  validityStatus    ValidityStatus?
  ontologyVersion   String?
  validationSummary Json?
  accessPolicy      String?
  validFrom         DateTime?
  validUntil        DateTime?
  knownFrom         DateTime?
  knownUntil        DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  validationResults ValidationResult[]
  reviewDecisions   ReviewDecision[]
  sourceDocument    Document?          @relation(fields: [sourceDocumentId], references: [id], onDelete: Restrict)

  @@index([sourceDocumentId, createdAt])
}

model ValidationResult {
  id                String             @id @default(cuid())
  candidateFactId   String
  overallStatus     ValidationStatus
  severity          ValidationSeverity
  checks            Json
  recommendedAction String?
  createdAt         DateTime           @default(now())
  candidateFact     CandidateFact      @relation(fields: [candidateFactId], references: [id], onDelete: Restrict)
  graphPatches      GraphPatch[]

  @@index([candidateFactId, createdAt])
}

model ReviewDecision {
  id              String             @id @default(cuid())
  candidateFactId String
  reviewerId      String?
  decision        ReviewDecisionType
  reason          String?
  changedFields   Json?
  createdAt       DateTime           @default(now())
  candidateFact   CandidateFact      @relation(fields: [candidateFactId], references: [id], onDelete: Restrict)

  @@index([candidateFactId, createdAt])
}

model ConflictRecord {
  id                   String         @id @default(cuid())
  conflictType         String
  subjectId            String
  subjectType          String?
  predicate            String
  candidateIds         String[]
  existingAssertionIds String[]
  status               ConflictStatus @default(needs_review)
  resolution           Json?
  ownerTeam            String?
  accessPolicy         String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  resolvedAt           DateTime?

  @@index([status, createdAt])
  @@index([subjectId, predicate])
}

model GraphPatch {
  id                  String               @id @default(cuid())
  patchType           String
  operations          Json
  evidenceAtomIds     String[]
  validationResultId  String?
  reviewStatus        ReviewStatus         @default(needs_review)
  publicationStatus   PublicationStatus    @default(unpublished)
  requiresHumanReview Boolean              @default(true)
  ontologyVersion     String
  accessPolicy        String
  createdAt           DateTime             @default(now())
  appliedAt           DateTime?
  validationResult    ValidationResult?    @relation(fields: [validationResultId], references: [id], onDelete: SetNull)
  publishedAssertions PublishedAssertion[]

  @@index([validationResultId])
  @@index([reviewStatus, publicationStatus, createdAt])
}

model PublishedAssertion {
  id                String            @id @default(cuid())
  subjectType       String
  subjectName       String
  predicate         String
  objectType        String
  objectName        String
  objectProperties  Json?
  evidenceAtomIds   Json
  sourceDocumentId  String?
  graphPatchId      String?
  reviewStatus      ReviewStatus      @default(approved)
  publicationStatus PublicationStatus @default(published)
  validityStatus    ValidityStatus
  validFrom         DateTime?
  validUntil        DateTime?
  knownFrom         DateTime          @default(now())
  knownUntil        DateTime?
  supersedes        String[]
  retractedBy       String?
  accessPolicy      String
  ontologyVersion   String
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  graphPatch        GraphPatch?       @relation(fields: [graphPatchId], references: [id], onDelete: Restrict)

  @@index([graphPatchId])
  @@index([subjectType, subjectName, predicate])
  @@index([validityStatus, validFrom, validUntil])
}

model SemanticMemoryItem {
  id               String                 @id @default(cuid())
  memoryType       String
  subjectType      String
  subjectId        String
  subjectName      String
  summary          String
  currentFacts     Json
  importantHistory Json?
  openConflictRefs Json?
  evidenceRefs     Json
  accessPolicy     String
  freshnessStatus  FreshnessStatus        @default(needs_verification)
  lastVerifiedAt   DateTime?
  ownerTeam        String?
  memoryVersion    Int                    @default(1)
  generatedFrom    MemoryGenerationSource @default(curated_kg)
  ontologyVersion  String
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@unique([memoryType, subjectType, subjectId])
  @@index([freshnessStatus, updatedAt])
  @@index([subjectType, subjectName])
}
