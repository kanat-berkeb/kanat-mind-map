generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ReviewStatus {
  candidate
  validated
  needs_review
  approved
  rejected
}

enum PublicationStatus {
  unpublished
  published
  publish_failed
}

enum ValidityStatus {
  active
  expired
  superseded
  retracted
  conflicted
}

enum ValidationStatus {
  passed
  failed
  warning
  skipped
  needs_review
}

enum ValidationSeverity {
  info
  warning
  error
  critical
}

enum ReviewDecisionType {
  approved
  rejected
}

model CandidateFact {
  id                String             @id @default(cuid())
  subjectName       String
  subjectType       String
  predicate         String
  objectName        String
  objectType        String
  objectProperties  Json?
  evidenceAtomIds   String[]
  sourceDocumentId  String?
  evidenceText      String
  llmConfidence     Float?
  approvalScore     Int?
  reviewStatus      ReviewStatus       @default(candidate)
  publicationStatus PublicationStatus  @default(unpublished)
  validityStatus    ValidityStatus?
  ontologyVersion   String?
  validationSummary Json?
  accessPolicy      String?
  validFrom         DateTime?
  validUntil        DateTime?
  knownFrom         DateTime?
  knownUntil        DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  validationResults ValidationResult[]
  reviewDecisions   ReviewDecision[]
}

model ValidationResult {
  id                String             @id @default(cuid())
  candidateFactId   String
  overallStatus     ValidationStatus
  severity          ValidationSeverity
  checks            Json
  recommendedAction String?
  createdAt         DateTime           @default(now())
  candidateFact     CandidateFact      @relation(fields: [candidateFactId], references: [id], onDelete: Restrict)

  @@index([candidateFactId, createdAt])
}

model ReviewDecision {
  id              String             @id @default(cuid())
  candidateFactId String
  reviewerId      String?
  decision        ReviewDecisionType
  reason          String?
  changedFields   Json?
  createdAt       DateTime           @default(now())
  candidateFact   CandidateFact      @relation(fields: [candidateFactId], references: [id], onDelete: Restrict)

  @@index([candidateFactId, createdAt])
}
