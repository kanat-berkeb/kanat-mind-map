{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kanat-mind-map.local/schemas/v1/graph-patch.schema.json",
  "title": "GraphPatch",
  "description": "Reviewable and auditable operation package for curated graph changes.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "patchType",
    "operations",
    "evidenceAtomIds",
    "validationResultIds",
    "reviewStatus",
    "publicationStatus",
    "requiresHumanReview",
    "ontologyVersion",
    "accessPolicy"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "patchType": { "type": "string", "minLength": 1 },
    "operations": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/operation" }
    },
    "evidenceAtomIds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "validationResultIds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "reviewStatus": {
      "type": "string",
      "enum": ["candidate", "validated", "needs_review", "approved", "rejected"]
    },
    "publicationStatus": {
      "type": "string",
      "enum": ["unpublished", "publish_pending", "published", "publish_failed"]
    },
    "requiresHumanReview": { "type": "boolean" },
    "ontologyVersion": { "type": "string", "minLength": 1 },
    "accessPolicy": { "type": "string", "minLength": 1 },
    "createdAt": { "type": "string", "format": "date-time" },
    "appliedAt": { "type": ["string", "null"], "format": "date-time" }
  },
  "$defs": {
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["op"],
      "properties": {
        "op": {
          "type": "string",
          "enum": [
            "ADD_NODE",
            "ADD_ASSERTION",
            "EXPIRE_ASSERTION",
            "SUPERSEDE_ASSERTION",
            "RETRACT_ASSERTION",
            "MARK_CONFLICTED",
            "UPDATE_ASSERTION_METADATA"
          ]
        },
        "nodeId": { "type": "string", "minLength": 1 },
        "nodeType": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "properties": { "type": "object", "additionalProperties": true },
        "assertionId": { "type": "string", "minLength": 1 },
        "replacementAssertionId": { "type": "string", "minLength": 1 },
        "subjectId": { "type": "string", "minLength": 1 },
        "subjectType": { "type": "string", "minLength": 1 },
        "predicate": { "type": "string", "minLength": 1 },
        "objectId": { "type": "string", "minLength": 1 },
        "objectType": { "type": "string", "minLength": 1 },
        "objectProperties": { "type": ["object", "null"], "additionalProperties": true },
        "validFrom": { "type": ["string", "null"], "format": "date" },
        "validUntil": { "type": ["string", "null"], "format": "date" },
        "validityStatus": {
          "type": "string",
          "enum": ["active", "expired", "superseded", "retracted", "conflicted", "unknown"]
        },
        "evidenceAtomIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "accessPolicy": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 },
        "conflictId": { "type": "string", "minLength": 1 },
        "metadata": { "type": "object", "additionalProperties": true }
      },
      "allOf": [
        {
          "if": { "properties": { "op": { "const": "ADD_NODE" } }, "required": ["op"] },
          "then": {
            "properties": { "nodeId": true, "nodeType": true, "name": true },
            "required": ["nodeId", "nodeType", "name"]
          }
        },
        {
          "if": { "properties": { "op": { "const": "ADD_ASSERTION" } }, "required": ["op"] },
          "then": {
            "properties": {
              "subjectId": true,
              "subjectType": true,
              "predicate": true,
              "objectId": true,
              "objectType": true
            },
            "required": ["subjectId", "subjectType", "predicate", "objectId", "objectType"]
          }
        },
        {
          "if": { "properties": { "op": { "const": "EXPIRE_ASSERTION" } }, "required": ["op"] },
          "then": {
            "properties": { "assertionId": true, "validUntil": true },
            "required": ["assertionId", "validUntil"]
          }
        },
        {
          "if": { "properties": { "op": { "const": "SUPERSEDE_ASSERTION" } }, "required": ["op"] },
          "then": {
            "properties": { "assertionId": true, "replacementAssertionId": true },
            "required": ["assertionId", "replacementAssertionId"]
          }
        },
        {
          "if": { "properties": { "op": { "const": "RETRACT_ASSERTION" } }, "required": ["op"] },
          "then": {
            "properties": { "assertionId": true, "reason": true },
            "required": ["assertionId", "reason"]
          }
        },
        {
          "if": { "properties": { "op": { "const": "MARK_CONFLICTED" } }, "required": ["op"] },
          "then": {
            "properties": { "assertionId": true, "conflictId": true },
            "required": ["assertionId", "conflictId"]
          }
        },
        {
          "if": {
            "properties": { "op": { "const": "UPDATE_ASSERTION_METADATA" } },
            "required": ["op"]
          },
          "then": {
            "properties": { "assertionId": true, "metadata": true },
            "required": ["assertionId", "metadata"]
          }
        }
      ]
    }
  }
}
