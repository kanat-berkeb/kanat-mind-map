{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kanat-mind-map.local/schemas/v1/candidate-fact.schema.json",
  "title": "CandidateFact",
  "description": "Evidence-bound candidate knowledge. It is not a published assertion.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "subjectName",
    "subjectType",
    "predicate",
    "objectName",
    "objectType",
    "objectProperties",
    "evidenceAtomIds",
    "evidenceText",
    "llmConfidence",
    "approvalScore",
    "validFrom",
    "validUntil",
    "ontologyVersion",
    "extractionWarnings"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "subjectName": { "type": "string", "minLength": 1 },
    "subjectType": { "type": "string", "minLength": 1 },
    "predicate": { "type": "string", "minLength": 1 },
    "objectName": { "type": "string", "minLength": 1 },
    "objectType": { "type": "string", "minLength": 1 },
    "objectProperties": {
      "type": ["object", "null"],
      "additionalProperties": true
    },
    "evidenceAtomIds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "sourceDocumentId": { "type": ["string", "null"], "minLength": 1 },
    "evidenceText": { "type": "string", "minLength": 1 },
    "llmConfidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "approvalScore": { "type": "integer", "minimum": 0, "maximum": 100 },
    "reviewStatus": {
      "type": "string",
      "enum": ["candidate", "validated", "needs_review", "approved", "rejected"]
    },
    "publicationStatus": {
      "type": "string",
      "enum": ["unpublished", "publish_pending", "published", "publish_failed"]
    },
    "validityStatus": {
      "type": "string",
      "enum": ["active", "expired", "superseded", "retracted", "conflicted", "unknown"]
    },
    "validFrom": { "type": ["string", "null"], "format": "date" },
    "validUntil": { "type": ["string", "null"], "format": "date" },
    "knownFrom": { "type": ["string", "null"], "format": "date-time" },
    "knownUntil": { "type": ["string", "null"], "format": "date-time" },
    "ontologyVersion": { "type": "string", "minLength": 1 },
    "extractionPromptVersion": { "type": "string", "minLength": 1 },
    "validationRuleVersion": { "type": "string", "minLength": 1 },
    "extractionWarnings": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "accessPolicy": { "type": "string", "minLength": 1 },
    "validationSummary": { "type": ["object", "null"], "additionalProperties": true },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  }
}
