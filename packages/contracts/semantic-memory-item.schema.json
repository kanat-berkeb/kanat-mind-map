{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kanat-mind-map.local/schemas/v1/semantic-memory-item.schema.json",
  "title": "SemanticMemoryItem",
  "description": "Evidence-linked memory derived only from curated knowledge or published assertions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "memoryType",
    "subjectType",
    "subjectId",
    "subjectName",
    "summary",
    "currentFacts",
    "importantHistory",
    "openConflictRefs",
    "evidenceRefs",
    "accessPolicy",
    "freshness",
    "memoryVersion",
    "generatedFrom"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "memoryType": { "type": "string", "minLength": 1 },
    "subjectType": { "type": "string", "minLength": 1 },
    "subjectId": { "type": "string", "minLength": 1 },
    "subjectName": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "currentFacts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/memoryFact" }
    },
    "importantHistory": {
      "type": "array",
      "items": { "$ref": "#/$defs/memoryFact" },
      "default": []
    },
    "openConflictRefs": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "evidenceRefs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/evidenceRef" }
    },
    "accessPolicy": { "type": "string", "minLength": 1 },
    "freshness": { "$ref": "#/$defs/freshness" },
    "ownerTeam": { "type": ["string", "null"], "minLength": 1 },
    "memoryVersion": { "type": "integer", "minimum": 1 },
    "generatedFrom": {
      "type": "string",
      "enum": ["curated_kg", "published_assertions"]
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "memoryFact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assertionId",
        "subjectName",
        "subjectType",
        "predicate",
        "objectName",
        "objectType",
        "validityStatus",
        "validFrom",
        "validUntil"
      ],
      "properties": {
        "assertionId": { "type": "string", "minLength": 1 },
        "subjectName": { "type": "string", "minLength": 1 },
        "subjectType": { "type": "string", "minLength": 1 },
        "predicate": { "type": "string", "minLength": 1 },
        "objectName": { "type": "string", "minLength": 1 },
        "objectType": { "type": "string", "minLength": 1 },
        "validityStatus": {
          "type": "string",
          "enum": ["active", "expired", "superseded", "retracted", "conflicted"]
        },
        "validFrom": { "type": ["string", "null"], "format": "date" },
        "validUntil": { "type": ["string", "null"], "format": "date" }
      }
    },
    "evidenceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["atomId"],
      "properties": {
        "atomId": { "type": "string", "minLength": 1 },
        "documentId": { "type": "string", "minLength": 1 },
        "excerpt": { "type": "string", "minLength": 1 }
      }
    },
    "freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "lastVerifiedAt"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["current", "stale", "needs_verification"]
        },
        "lastVerifiedAt": { "type": ["string", "null"], "format": "date-time" },
        "staleReason": { "type": ["string", "null"], "minLength": 1 }
      }
    }
  }
}
