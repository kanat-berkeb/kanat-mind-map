{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kanat-mind-map.local/schemas/v1/published-assertion.schema.json",
  "title": "PublishedAssertion",
  "description": "Approved assertion persisted for audit and projected to the curated graph.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "subjectId",
    "subjectType",
    "subjectName",
    "predicate",
    "objectId",
    "objectType",
    "objectName",
    "objectProperties",
    "evidenceAtomIds",
    "reviewStatus",
    "publicationStatus",
    "validityStatus",
    "validFrom",
    "validUntil",
    "knownFrom",
    "knownUntil",
    "supersedes",
    "graphPatchId",
    "accessPolicy",
    "ontologyVersion"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "subjectId": { "type": "string", "minLength": 1 },
    "subjectType": { "type": "string", "minLength": 1 },
    "subjectName": { "type": "string", "minLength": 1 },
    "predicate": { "type": "string", "minLength": 1 },
    "objectId": { "type": "string", "minLength": 1 },
    "objectType": { "type": "string", "minLength": 1 },
    "objectName": { "type": "string", "minLength": 1 },
    "objectProperties": { "type": ["object", "null"], "additionalProperties": true },
    "evidenceAtomIds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "sourceDocumentId": { "type": ["string", "null"], "minLength": 1 },
    "reviewStatus": { "const": "approved" },
    "publicationStatus": { "const": "published" },
    "validityStatus": {
      "type": "string",
      "enum": ["active", "expired", "superseded", "retracted", "conflicted"]
    },
    "validFrom": { "type": ["string", "null"], "format": "date" },
    "validUntil": { "type": ["string", "null"], "format": "date" },
    "knownFrom": { "type": "string", "format": "date-time" },
    "knownUntil": { "type": ["string", "null"], "format": "date-time" },
    "supersedes": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "retractedBy": { "type": ["string", "null"], "minLength": 1 },
    "graphPatchId": { "type": "string", "minLength": 1 },
    "accessPolicy": { "type": "string", "minLength": 1 },
    "ontologyVersion": { "type": "string", "minLength": 1 },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  }
}
